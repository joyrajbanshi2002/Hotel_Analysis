#value_counts() → counts values
#normalize=True → converts counts into percentage/proportion

resort_hotel=df[df["hotel"]=='Resort Hotel']
resort_hotel["is_canceled"].value_counts(normalize=True)

city_hotel = df[df["hotel"]=='City Hotel']
city_hotel["is_canceled"].value_counts(normalize=True)

#This code groups the Resort Hotel data by date and calculates the average ADR (Average Daily Rate) for each date.
#Groups rows based on reservation status date.

resort_hotel = resort_hotel.groupby("reservation_status_date")[["adr"]].mean()
city_hotel = city_hotel.groupby("reservation_status_date")[["adr"]].mean()

#Comparison between City & Resort hotels
#Which hotel type has higher ADR over time

#| Code                          | Meaning              |
#| ----------------------------- | -------------------- |
#| `plt.figure(figsize=(20,10))` | Creates large graph  |
#| `plt.title()`                 | Adds graph title     |
#| `plt.plot()`                  | Draws line graph     |
#| `resort_hotel.index`          | Dates on X-axis      |
#| `resort_hotel["adr"]`         | ADR values on Y-axis |
#| `label=`                      | Name shown in legend |
#| `plt.legend()`                | Displays legend      |
#| `plt.show()`                  | Displays graph       |



plt.figure(figsize=(20,10))
plt.title("Average Daily Rate in City and Resort Hotel",fontsize=30)
plt.plot(resort_hotel.index,resort_hotel["adr"],label="Resort Hotel")
plt.plot(city_hotel.index,city_hotel["adr"],label="City Hotel")
plt.legend(fontsize=20)
plt.show

